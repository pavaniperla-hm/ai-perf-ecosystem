# ── Grafana Cloud — k6 Prometheus Remote Write ────────────────────────────────
# Copy this file to .env and fill in your Grafana API token.
# .env is gitignored and will never be committed.
#
# Generate a token at grafana.com → My Account → Access Policies
# Required scopes: metrics:write  (for k6 Prometheus push)
#                  logs:write     (for Promtail Loki push)

K6_PROMETHEUS_RW_SERVER_URL=https://prometheus-prod-39-prod-eu-north-0.grafana.net/api/prom/push
K6_PROMETHEUS_RW_USERNAME=2997542
K6_PROMETHEUS_RW_PASSWORD=your_grafana_api_token_here

# ── Grafana Cloud — Loki (log shipping via Promtail) ──────────────────────────
# Loki URL and numeric user ID shown at:
#   https://myperformanceproject.grafana.net → Connections → Add new connection → Loki

LOKI_URL=https://logs-prod-eu-north-0.grafana.net
LOKI_USERNAME=your_loki_numeric_user_id_here
LOKI_PASSWORD=your_grafana_access_policy_token_here
