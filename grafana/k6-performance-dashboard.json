{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "k6 load test metrics streamed live via experimental-prometheus-rw. Filter by testName to compare runs.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["k6", "performance", "load-testing"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "k6 Performance Dashboard",
  "uid": "k6-perf-dashboard",
  "version": 1,

  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-myperformanceproject-prom"
        },
        "definition": "label_values(k6_vus, testName)",
        "hide": 0,
        "includeAll": true,
        "label": "Test Name",
        "multi": false,
        "name": "testName",
        "options": [],
        "query": {
          "query": "label_values(k6_vus, testName)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-myperformanceproject-prom"
        },
        "definition": "label_values(k6_vus, testType)",
        "hide": 0,
        "includeAll": true,
        "label": "Test Type",
        "multi": false,
        "name": "testType",
        "options": [],
        "query": {
          "query": "label_values(k6_vus, testType)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },

  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Error Rate %",
      "description": "Percentage of failed HTTP requests. Threshold: red if > 1%.",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_http_req_failed{testName=~\"$testName\"} * 100",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "HTTP Requests Total",
      "description": "Total number of HTTP requests made during the test.",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "sum(k6_http_reqs_total{testName=~\"$testName\"})",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Checks Success Rate",
      "description": "Percentage of k6 checks that passed.",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_checks{testName=~\"$testName\"} * 100",
          "legendFormat": "Check Pass Rate",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Virtual Users",
      "description": "Number of active virtual users over the test duration.",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_vus{testName=~\"$testName\"}",
          "legendFormat": "Active VUs",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_vus_max{testName=~\"$testName\"}",
          "legendFormat": "Max VUs",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Max VUs" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4, 4] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "description": "HTTP requests per second and iterations per second over time.",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "rate(k6_http_reqs_total{testName=~\"$testName\"}[$__rate_interval])",
          "legendFormat": "HTTP req/s",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "rate(k6_iterations_total{testName=~\"$testName\"}[$__rate_interval])",
          "legendFormat": "Iterations/s",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Response Time p(95)",
      "description": "HTTP request duration percentiles over time. All values in milliseconds.",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p(95)",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.90, sum(rate(k6_http_req_duration_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p(90)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p(99)",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "sum(rate(k6_http_req_duration_sum{testName=~\"$testName\"}[$__rate_interval])) / sum(rate(k6_http_req_duration_count{testName=~\"$testName\"}[$__rate_interval])) * 1000",
          "legendFormat": "avg",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true,
          "calcs": ["lastNotNull", "min", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p(99)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p(95)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p(90)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "avg" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      }
    },

    {
      "id": 7,
      "type": "barchart",
      "title": "Response Time by Transaction — avg / p(90) / p(95)",
      "description": "Per-transaction response times. Covers both checkout-flow metrics (baseline/peak/stress) and weighted-scenario metrics (realistic-load).",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_login_page_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "Login Page — p(95)",
          "refId": "A1"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_products_page_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "Products Page — p(95)",
          "refId": "A2"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_product_detail_page_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "Product Detail Page — p(95)",
          "refId": "A3"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_checkout_page_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "Checkout Page — p(95)",
          "refId": "A4"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_products_list_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "Products List — p(95)",
          "refId": "B1"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_product_detail_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "Product Detail — p(95)",
          "refId": "B2"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_user_login_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "User Login — p(95)",
          "refId": "B3"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_create_order_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "Create Order — p(95)",
          "refId": "B4"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "histogram_quantile(0.95, sum(rate(k6_txn_order_history_bucket{testName=~\"$testName\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "Order History — p(95)",
          "refId": "B5"
        }
      ],
      "options": {
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "fillOpacity": 80,
        "gradientMode": "none",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "xTickLabelRotation": -30,
        "xTickLabelSpacing": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      }
    }

  ]
}
