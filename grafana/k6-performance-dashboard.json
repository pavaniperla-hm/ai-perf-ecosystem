{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "k6 load test metrics streamed live via experimental-prometheus-rw.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["k6", "performance", "load-testing"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "k6 Performance Dashboard v2",
  "uid": "k6-perf-dashboard-v2",
  "version": 1,

  "templating": { "list": [] },

  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Error Rate %",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "avg(k6_http_req_failed) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "HTTP Requests Total",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "sum(k6_http_reqs_total)",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "blue", "value": null } ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Checks Success Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "avg(k6_checks) * 100",
          "legendFormat": "Check Pass Rate",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Virtual Users",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_vus",
          "legendFormat": "Active VUs",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_vus_max",
          "legendFormat": "Max VUs",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "sum(rate(k6_http_reqs_total[$__rate_interval]))",
          "legendFormat": "HTTP req/s",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Response Time — avg / p(90) / p(95) / p(99)",
      "description": "HTTP request duration over time in milliseconds. Uses k6 gauge metrics from experimental-prometheus-rw.",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_http_req_duration * 1000",
          "legendFormat": "{{quantile}} — {{__name__}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_http_req_duration{quantile=\"0.95\"} * 1000",
          "legendFormat": "p(95)",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_http_req_duration{quantile=\"0.90\"} * 1000",
          "legendFormat": "p(90)",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "k6_http_req_duration{quantile=\"0.5\"} * 1000",
          "legendFormat": "median",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "min", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p(99)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p(95)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p(90)" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "median" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Response Time by Transaction",
      "description": "Per-transaction response times in milliseconds.",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "{__name__=~\"k6_.*_duration|k6_.*_p95|k6_.*_trend\", quantile=\"0.95\"} * 1000",
          "legendFormat": "{{__name__}} p(95)",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
        },
        "overrides": []
      }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Error Rate Over Time",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-myperformanceproject-prom"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-myperformanceproject-prom"
          },
          "expr": "avg(k6_http_req_failed) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    }

  ]
}